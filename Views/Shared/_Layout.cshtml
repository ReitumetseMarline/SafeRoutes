<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SafeRoute</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --sr-green: #1db954;
            --sr-dark: #121212;
            --sr-card: #1e1e1e;
            --sr-muted: #a0a0a0;
        }
        body { background: var(--sr-dark); color: #f0f0f0; font-family: 'Segoe UI', sans-serif; }
        .navbar { background: #000 !important; border-bottom: 2px solid var(--sr-green); }
        .navbar-brand { color: var(--sr-green) !important; font-weight: 700; font-size: 1.4rem; letter-spacing: 1px; }
        .navbar-brand span { color: #fff; }
        .sr-card { background: var(--sr-card); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.2rem; }
        .btn-safe { background: var(--sr-green); color: #000; font-weight: 700; border: none; padding: .75rem 2rem; border-radius: 8px; }
        .btn-safe:hover { background: #17a847; color: #000; }
        .safety-badge { display: inline-block; padding: .3rem .8rem; border-radius: 20px; font-weight: 700; font-size: .85rem; }
        .safety-high { background: #1a4d2e; color: var(--sr-green); }
        .safety-mid  { background: #4d3a00; color: #ffc107; }
        .safety-low  { background: #4d1010; color: #ff5555; }
        .form-control, .form-select { background: #2a2a2a; border: 1px solid #444; color: #f0f0f0; }
        .form-control:focus, .form-select:focus { background: #2a2a2a; color: #f0f0f0; border-color: var(--sr-green); box-shadow: 0 0 0 .2rem rgba(29,185,84,.25); }
        .form-select option { background: #2a2a2a; }
        footer { background: #000; border-top: 1px solid #333; color: var(--sr-muted); padding: 1rem 0; margin-top: 2rem; }
        #map { height: 460px; border-radius: 12px; z-index: 1; }
        .disclaimer { background: #1a1a2e; border-left: 4px solid #ffc107; padding: 1rem 1.2rem; border-radius: 8px; font-size: .875rem; color: #ccc; }
        .route-tab.active-route { border: 2px solid var(--sr-green) !important; }
        .ai-box { background: #0d1f12; border-left: 4px solid var(--sr-green); padding: 1rem 1.2rem; border-radius: 8px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Safe<span>Route</span></a>
        </div>
    </nav>

    <div class="container mt-4">
        <main>@RenderBody()</main>
    </div>

    <footer>
        <div class="container text-center small">
            SafeRoute &mdash; Built for AI for Good &bull; Crime data: SAPS 2023 &bull; Routing: OpenStreetMap
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
